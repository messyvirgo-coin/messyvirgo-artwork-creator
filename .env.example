# Required for generation. Get a key at https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-replace-me

# OpenRouter image model (default: Seedream 4.5)
AVATAR_REFERENCE_MODEL=bytedance-seed/seedream-4.5

# Prompt library and default generation output directory
AVATAR_REFERENCE_PROMPTS=config/avatar_prompts.yaml
AVATAR_REFERENCE_OUTPUT=output/avatar-reference-set
